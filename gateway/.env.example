# ═══════════════════════════════════════════════════════
# 🌊 Pacific Gateway — Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# ── Backend AI (Lambda GPU) ──
PACIFIC_BACKEND_URL=https://pacific.grrn.io
PACIFIC_API_KEY=your-vllm-api-key-here

# ── MongoDB (user accounts + OTP) ──
MONGO_URI=mongodb://localhost:27017
MONGO_DB=pacific

# ── Email (OTP delivery) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@pacific.grrn.io

# ── Stripe (subscription billing) ──
STRIPE_SECRET_KEY=sk_live_your-stripe-key

# ── Admin ──
GATEWAY_ADMIN_KEY=random-64-char-admin-token

# ── Optional ──
# TRIAL_DAYS=7
# RATE_LIMIT_PER_MINUTE=50
# LOG_LEVEL=INFO
