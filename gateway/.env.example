# ═══════════════════════════════════════════════════════
# 🌊 Pacific Gateway — Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# ── Backend AI (Lambda GPU) ──
PACIFIC_BACKEND_URL=https://pacific.grrn.io
PACIFIC_API_KEY=your-vllm-api-key-here

# ── Microsoft Store B2B Auth ──
MS_STORE_ID=your-store-product-id
MS_TENANT_ID=your-azure-ad-tenant-id
MS_CLIENT_ID=your-azure-ad-client-id
MS_CLIENT_SECRET=your-azure-ad-client-secret
MS_SERVICE_TICKET=your-partner-center-service-ticket

# ── Admin ──
GATEWAY_ADMIN_KEY=random-64-char-admin-token

# ── Optional ──
# RATE_LIMIT_PER_MINUTE=50
# LOG_LEVEL=INFO
# MS_COLLECTIONS_URL=https://collections.mp.microsoft.com/v8.0/collections/b2bLicensePreview
